# ──────────────────────────────────────────────────────────────
# Environment-specific configuration — changes per developer/env.
# Static defaults live in config/default.yaml.
# ──────────────────────────────────────────────────────────────

# REQUIRED: Path to the codebase to analyze
CODEBASE_PATH=C:\workspace\code_assignment\spring-rest-sakila

# Repository URL (appears in output metadata)
CODEBASE_REPO_URL=https://github.com/codejsha/spring-rest-sakila

# OpenAI API key (required for real analysis)
#OPENAI_API_KEY=

# Set to "false" to use real OpenAI API (default: true = mock mode)
CODEBASE_MOCK=true

# Output directory (default: output)
# CODEBASE_OUTPUT_DIR=output
